# ── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...            # required — get from https://aistudio.google.com/app/apikey
EMBEDDING_MODEL=models/embedding-001   # 768-dim, free tier
LLM_MODEL=gemini-1.5-flash                 # or gemini-1.5-pro / gemini-2.0-flash
LLM_TEMPERATURE=0.2
MAX_TOKENS=1024

# ── Vector store ─────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=data/faiss_index
METADATA_DB_PATH=data/metadata.db

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_CHUNKS=5

# ── Auth ─────────────────────────────────────────────────────────────────────
API_KEY_HEADER=X-API-Key
API_KEYS=dev-secret-key          # comma-separated, e.g. key1,key2,key3

# ── Upload ───────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=20
